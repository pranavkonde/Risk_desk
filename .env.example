# Copy to .env and adjust (never commit .env)

# testnet | mainnet
PACIFICA_NETWORK=testnet

# Optional: full override of REST base (must include /api/v1)
# PACIFICA_REST_URL=https://test-api.pacifica.fi/api/v1

# Default wallet shown in the Risk Desk sidebar (read-only; public address only)
# PACIFICA_ACCOUNT=

# For scripts/set_position_tpsl.py only — use a dedicated test wallet
# PACIFICA_PRIVATE_KEY=
